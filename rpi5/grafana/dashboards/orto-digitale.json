      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-garden" },
          "query": "from(bucket: \"garden\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"soil_moisture\" and r._field == \"value\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.sensor_id + \" (A\" + r.aiuola + \" \" + r.position + \")\" }))\n  |> yield(name: \"mean\")",
          "refId": "A"
