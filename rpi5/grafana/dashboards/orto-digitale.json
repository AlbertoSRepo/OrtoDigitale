            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 40 },
              { "color": "blue", "value": 65 }
            ]
          },
          "unit": "percent"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "WH51_01 (A1 near)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WH51_02 (A1 far)" },  "properties": [{ "id": "color", "value": { "fixedColor": "#37872D", "mode": "fixed" } }] },
