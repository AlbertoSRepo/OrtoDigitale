# ==============================================================================
# Orto Digitale — template credenziali per docker-compose
# ==============================================================================
# Copiare questo file in `.env` e completare i valori.
# Il file .env finale DEVE avere permessi 600 e NON essere committato.
#
# Generare password sicure con:
#   openssl rand -base64 24
# Generare token InfluxDB tramite UI (http://<rpi5>:8086) o CLI:
#   influx auth create --org orto-digitale --all-access -t $INFLUXDB_ADMIN_TOKEN
# ==============================================================================

# ---- InfluxDB 2.x ------------------------------------------------------------
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=<scegliere-min-8-caratteri>
INFLUXDB_ORG=orto-digitale
INFLUXDB_BUCKET=garden
INFLUXDB_RETENTION=120d

# Token admin — generato al primo `docker compose up -d` da InfluxDB.
# Estrarlo con: `docker exec influxdb cat /etc/influxdb2/influx-configs`
INFLUXDB_ADMIN_TOKEN=<inserire-dopo-setup-iniziale>

# Token con sole permissioni R+W su bucket `garden` per Node-RED.
# Generare dopo il setup con:
#   docker exec influxdb influx auth create \
#     --org orto-digitale \
#     --read-bucket <id-garden> --write-bucket <id-garden> \
#     --description "nodered-rw" -t $INFLUXDB_ADMIN_TOKEN
INFLUXDB_TOKEN_NODERED_RW=<generare-dopo-setup>

# Usati negli step successivi:
INFLUXDB_TOKEN_GRAFANA_RO=<generare-in-step5>
INFLUXDB_TOKEN_EXPORT_RO=<generare-in-step6>

# ---- MQTT (Mosquitto) --------------------------------------------------------
# Password degli utenti MQTT — vengono hashate nel password_file via mosquitto_passwd.
# Le variabili restano necessarie qui perché lo script verify_rpi5.sh le usa
# per eseguire test di autenticazione e il GW3000 richiede la password in chiaro
# da incollare nella sua interfaccia web.

# Nomi var usati realmente da docker-compose.yml: MQTT_PASS_*.
# Gli alias MQTT_PWD_* restano per compatibilita' storica con lo script verify_rpi5.sh.
MQTT_PASS_GW3000=<generare-openssl-rand>
MQTT_PASS_NODERED=<generare-openssl-rand>
MQTT_PASS_ZIGBEE2MQTT=<generare-openssl-rand>
MQTT_PASS_MONITOR=<generare-openssl-rand>

# ---- Grafana -----------------------------------------------------------------
# Le credenziali Grafana sono gia' hardcoded nel docker-compose.yml (admin/OrtoDigitale2026).
# Qui solo come promemoria; cambiarle in docker-compose.yml se si vuole altro:
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=OrtoDigitale2026

# ---- Timezone ----------------------------------------------------------------
TZ=Europe/Rome
